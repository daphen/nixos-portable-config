      "    ",
      "    ${4:// Process and return new state}",
      "    return ${5:prevState};",
      "  },",
      "  ${6:{\\}}",
      ");"
    ],
    "description": "useActionState hook with form data extraction"
  },
  "useActionState with Types (React 19)": {
    "prefix": "uacf",
    "body": [
