      "    const ${5:value} = formData.get('${6:fieldName}') as string;",
      "    ",
      "    ${7:// Process and return new state}",
      "    return prevState;",
      "  },",
      "  { ${2:data}: [] }",
      ");"
    ],
    "description": "useActionState with TypeScript types"
  },
  "useOptimistic Hook (React 19)": {
    "prefix": "uop",
    "body": [
      "const [${1:optimistic}${2:State}, ${3:add}${2}/(.)(.*)/${1:/upcase}$2/}}] = useOptimistic(",
      "  ${2:state},",
      "  (currentState, ${4:optimisticValue}) => {",
      "    return [...currentState, ${4:optimisticValue}];",
      "  }",
      ");"
