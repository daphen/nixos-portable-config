{
  "useState Hook": {
    "prefix": "us",
    "body": ["const [${1:state}, set${1/(.*)/\\u$1/}] = useState$2(${3:''});"],
    "description": "useState hook"
  },
  "useState with Array": {
    "prefix": "usa",
    "body": [
      "const [${1:items}, set${1/(.*)/\\u$1/}] = useState<${2:string}[]>([]);"
