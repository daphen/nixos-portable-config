      "  ${4:// form logic}",
      "};",
      "",
      "<form action={handle${1:Submit}}>",
      "  <input name=\"${3:name}\" placeholder=\"${5:}\" />",
      "  <button type=\"submit\">${6:Submit}</button>",
      "</form>"
    ],
    "description": "React 19 form with action prop and FormData (uncontrolled)"
  },
