  "Async Form Handler (React 19)": {
    "prefix": "asyncform",
    "body": [
      "const formRef = useRef<HTMLFormElement>(null);",
      "const [isLoading, setIsLoading] = useState(false);",
      "",
      "const handle${1:Submit} = async (formData: FormData) => {",
      "  const ${2:value} = formData.get('${3:name}') as string;",
      "  if (!${2:value}?.trim()) return;",
      "  ",
      "  setIsLoading(true);",
      "  ",
      "  try {",
      "    ${4:// async operation}",
      "    formRef.current?.reset();",
      "  } catch (error) {",
      "    console.error(error);",
      "  } finally {",
      "    setIsLoading(false);",
      "  }",
      "};",
      "",
      "<form ref={formRef} action={handle${1:Submit}}>",
      "  <input name=\"${3:name}\" disabled={isLoading} />",
      "  <button type=\"submit\" disabled={isLoading}>",
      "    {isLoading ? 'Loading...' : '${5:Submit}'}",
      "  </button>",
      "</form>"
    ],
    "description": "Async form handler with loading state and form reset"
  }
