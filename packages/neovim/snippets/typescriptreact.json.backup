  },
  "useEffect Hook": {
    "prefix": "ue",
    "body": [
      "useEffect(() => {",
      "  ${1:// effect code}",
      "  ",
      "  return () => {",
      "    ${2:// cleanup}",
      "  };",
      "}, [${3:}]);"
    ],
    "description": "useEffect with cleanup"
  },
  "useEffect Simple": {
    "prefix": "ues",
    "body": ["useEffect(() => {", "  ${1:// effect code}", "}, [${2:}]);"],
    "description": "useEffect without cleanup"
  },
  "useLayoutEffect": {
    "prefix": "ule",
    "body": [
      "useLayoutEffect(() => {",
      "  ${1:// DOM mutation/measurement}",
      "}, [${2:}]);"
    ],
    "description": "useLayoutEffect (runs before paint - for DOM mutations)"
  },
  "useRef Hook": {
    "prefix": "ur",
    "body": ["const ${1:ref} = useRef<HTML${2:Div}Element>(null);"],
    "description": "useRef hook"
  },
  "Form with Action (React 19)": {
    "prefix": "formaction",
    "body": [
      "const handle${1:Submit} = (formData: FormData) => {",
